# Python 字节码 / 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 打包 / 构建产物
build/
dist/
*.egg-info/
.eggs/

# 虚拟环境
.venv/
venv/
env/
ENV/

# uv
.uv/

# 测试 / 覆盖率
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# 环境变量与密钥
.env
.env.*
!.env.example

# 输入数据（PDF、本地 SQLite 库，体积大/含数据，不入库）
data/

# 产物目录：忽略内容，但保留目录说明与占位
output/*
!output/.gitkeep
!output/README.md

# 编辑器 / 系统
.idea/
.vscode/
*.swp
.DS_Store
*.pdf
*.Identifier